{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "snorkel-report",
  "compatibility_date": "2026-04-24",
  "main": "worker.js",
  "assets": {
    "directory": "."
  },
  "triggers": {
    "crons": ["*/30 * * * *"]
  },
  "d1_databases": [
    {
      "binding": "FEEDBACK_DB",
      "database_name": "snorkel-feedback",
      "database_id": "f34e655e-2ada-4b29-9928-48f186c899d6"
    }
  ]
}
